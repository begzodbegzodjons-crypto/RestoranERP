# OshxonaERP - Environment Variables Example
# ====================================================
# Nusxa oling va .env.local yoki Vercel environment variables'ga qo'ying

# === DATABASE PROVIDER ===
# Local dev: sqlite
# Production (Supabase): postgresql
DATABASE_PROVIDER=sqlite

# === DATABASE URL ===
# Local SQLite:
DATABASE_URL=file:./db/custom.db

# Supabase PostgreSQL (production):
# 1. Supabase dashboard → Settings → Database → Connection string
# 2. Use "Connection pooling" URL (port 6543) for Vercel serverless
# 3. Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# DATABASE_URL=postgresql://postgres.abcdefgh:[YOUR_PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (for migrations only, NOT for runtime):
# DIRECT_URL=postgresql://postgres.abcdefgh:[YOUR_PASSWORD]@aws-0-region.supabase.com:5432/postgres

# OshxonaERP - Environment Variables Example
# ====================================================
# Nusxa oling va .env.local yoki production environment variables'ga qo'ying
#
# === DEPLOYMENT VARIANTLARI ===
# 1. Cloudflare Pages + TiDB Cloud (asosiy tavsiya etilgan variant)
# 2. Vercel + Supabase (alternativ)
# 3. Local dev (SQLite, hech qanday env kerak emas)

# ============================================================
# 1) CLOUDFLARE PAGES + TIDB CLOUD (PRODUCTION)
# ============================================================
# Cloudflare Pages dashboard → Settings → Environment variables
# Hammasini "Secret" sifatida qo'shing.
#
# TiDB Cloud Serverless cluster yarating: https://tidbcloud.com
# Dashboard → Clusters → Serverless → Connect → General connection
# Format (TCP - migrations uchun):
#   mysql://<user>:<password>@<host>:4000/<database>?ssl={"rejectUnauthorized":true}
#
# DATABASE_URL - TCP orqali (prisma migrate/db push uchun lokal CI muhitda)
# CF Workers da TCP ishlamagani uchun TIDB_DATABASE_URL ishlatamiz
DATABASE_URL="mysql://xxxxxxxxx.root:password@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/oshxona_erp?ssl={"rejectUnauthorized":true}"

# TIDB_DATABASE_URL - HTTP orqali (CF Workers runtime da ishlaydi)
# URL formati DATABASE_URL bilan bir xil, faqat boshqa env nomi
# @tidbcloud/serverless driver shu URL ni ishlatadi
TIDB_DATABASE_URL="mysql://xxxxxxxxx.root:password@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/oshxona_erp?ssl={"rejectUnauthorized":true}"

# Deploy target - Cloudflare Pages build'ini faollashtirish uchun
DEPLOY_TARGET="cloudflare"

# ============================================================
# 2) ALTERNATIV: VERCEL + SUPABASE (POSTGRESQL)
# ============================================================
# DATABASE_URL=postgresql://postgres.abcdefgh:[YOUR_PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.abcdefgh:[YOUR_PASSWORD]@aws-0-region.supabase.com:5432/postgres
# DEPLOY_TARGET=vercel

# ============================================================
# 3) LOCAL DEV (SQLite - hech qanday env kerak emas)
# ============================================================
# Local dev'da SQLite avtomatik ishlaydi, env o'rnatish shart emas:
# DATABASE_URL=file:./db/custom.db
# (package.json'da default sifatida shunday)

# ============================================================
# SUPABASE STORAGE (rasm yuklash uchun - ixtiyoriy)
# ============================================================
# Production'da Supabase Storage ishlatish tavsiya etiladi
# (Cloudflare Pages'da ham ishlaydi - fetch API orqali)
# SUPABASE_URL=https://abcdefgh.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_BUCKET_NAME=product-images
#
# Agar Supabase Storage sozlanmagan bo'lsa,
# rasm base64 sifatida database'da saqlanadi (local dev uchun).

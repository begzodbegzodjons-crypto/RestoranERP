# === LOCAL DEVELOPMENT (SQLite) ===
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:/home/z/my-project/db/custom.db

# === PRODUCTION (Supabase + Vercel) ===
# Supabase project settings → Settings → Database → Connection string
# Use connection POOLER URL (port 6543) for Vercel serverless
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[project]:[password]@aws-0-[region].supabase.com:5432/postgres

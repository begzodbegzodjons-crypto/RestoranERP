// ====================================================================
// OshxonaERP - Prisma Schema (Supabase PostgreSQL uchun)
// ====================================================================
// Production uchun (Supabase): Bu faylni schema.prisma ga nusxalang
// Va .env faylida DATABASE_URL=postgresql://... ni qo'ying
// ====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// TENANT (RESTAURANT) - har bir restoran alohida
// ============================================================
model Restaurant {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  passwordHash    String
  phone           String?
  address         String?
  logoUrl         String?
  currency        String   @default("UZS")
  taxRate         Float    @default(0.0)

  // Trial / Activation logic
  status          String   @default("trial") // trial | active | blocked
  trialStart      DateTime @default(now())
  trialEnd        DateTime
  activatedAt     DateTime?
  activationEnd   DateTime?
  activationCode  String?

  // Admin tomonidan boshqarish
  blockedByAdmin  Boolean  @default(false)
  blockedReason   String?
  blockedAt       DateTime?
  adminNotes      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branches        Branch[]
  categories      Category[]
  products        Product[]
  ingredients     Ingredient[]
  recipes         Recipe[]
  inventoryItems  InventoryItem[]
  suppliers       Supplier[]
  purchases       Purchase[]
  sales           Sale[]
  expenses        Expense[]
  customers       Customer[]
  staff           Staff[]
  tables          RestaurantTable[]
  sessions        Session[]

  @@index([status])
  @@index([createdAt])
}

model Session {
  id            String   @id @default(cuid())
  restaurantId  String
  token         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

// ============================================================
// ACTIVATION CODES - admin tomonidan generatsiya qilinadi
// ============================================================
model ActivationCode {
  id            String    @id @default(cuid())
  code          String    @unique
  status        String    @default("unused") // unused | used
  validDays     Int       @default(30)
  createdAt     DateTime  @default(now())
  usedBy        String?
  usedAt        DateTime?
  expiresAt     DateTime?

  @@index([status])
  @@index([createdAt])
}

model Branch {
  id            String   @id @default(cuid())
  restaurantId  String
  name          String
  address       String?
  phone         String?
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Category {
  id            String   @id @default(cuid())
  restaurantId  String
  name          String
  description   String?
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  products      Product[]

  @@index([restaurantId])
}

model Product {
  id            String   @id @default(cuid())
  restaurantId  String
  categoryId    String?
  name          String
  description   String?
  price         Float
  cost          Float    @default(0)
  unit          String   @default("dona")
  imageUrl      String?
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category      Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recipes       Recipe[]
  saleItems     SaleItem[]

  @@index([restaurantId])
  @@index([categoryId])
}

model Ingredient {
  id            String   @id @default(cuid())
  restaurantId  String
  name          String
  unit          String
  stock         Float    @default(0)
  minStock      Float    @default(0)
  unitPrice     Float    @default(0)
  supplierId    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplier      Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  recipes       Recipe[]
  inventoryItems InventoryItem[]
  purchaseItems PurchaseItem[]

  @@index([restaurantId])
}

model Recipe {
  id            String   @id @default(cuid())
  restaurantId  String
  productId     String
  ingredientId  String
  quantity      Float
  unit          String
  cost          Float    @default(0)

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
  @@index([restaurantId, productId])
}

model InventoryItem {
  id            String   @id @default(cuid())
  restaurantId  String
  ingredientId  String
  type          String
  quantity      Float
  unitPrice     Float
  reason        String?
  refType       String?
  refId         String?
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([restaurantId, ingredientId])
  @@index([createdAt])
}

model Supplier {
  id            String   @id @default(cuid())
  restaurantId  String
  name          String
  phone         String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now())

  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  ingredients   Ingredient[]
  purchases     Purchase[]

  @@index([restaurantId])
}

model Purchase {
  id            String   @id @default(cuid())
  restaurantId  String
  supplierId    String?
  invoiceNo     String?
  totalAmount   Float    @default(0)
  paidAmount    Float    @default(0)
  status        String   @default("paid")
  notes         String?
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplier      Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items         PurchaseItem[]

  @@index([restaurantId])
  @@index([supplierId])
  @@index([createdAt])
}

model PurchaseItem {
  id            String   @id @default(cuid())
  purchaseId    String
  ingredientId  String
  quantity      Float
  unit          String
  unitPrice     Float
  total         Float

  purchase      Purchase   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([ingredientId])
}

model Sale {
  id            String   @id @default(cuid())
  restaurantId  String
  invoiceNo     String
  tableId       String?
  customerId    String?
  staffId       String?
  subtotal      Float
  discount      Float    @default(0)
  taxAmount     Float    @default(0)
  total         Float
  paidAmount    Float    @default(0)
  paymentMethod String   @default("cash")
  status        String   @default("completed")
  costOfGoods   Float    @default(0)
  profit        Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table         RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customer      Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  staff         Staff?     @relation(fields: [staffId], references: [id], onDelete: SetNull)
  items         SaleItem[]

  @@index([restaurantId])
  @@index([customerId])
  @@index([tableId])
  @@index([createdAt])
  @@index([status])
}

model SaleItem {
  id            String   @id @default(cuid())
  saleId        String
  productId     String
  quantity      Float
  unitPrice     Float
  unitCost      Float
  total         Float
  totalCost     Float

  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

model Customer {
  id            String   @id @default(cuid())
  restaurantId  String
  name          String
  phone         String?
  email         String?
  address       String?
  notes         String?
  totalOrders   Int      @default(0)
  totalSpent    Float    @default(0)
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sales         Sale[]

  @@index([restaurantId])
}

model Staff {
  id            String   @id @default(cuid())
  restaurantId  String
  name          String
  phone         String?
  position      String?
  salary        Float    @default(0)
  status        String   @default("active")
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sales         Sale[]

  @@index([restaurantId])
}

model RestaurantTable {
  id            String   @id @default(cuid())
  restaurantId  String
  name          String
  seats         Int      @default(4)
  status        String   @default("free")
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sales         Sale[]

  @@index([restaurantId])
}

model Expense {
  id            String   @id @default(cuid())
  restaurantId  String
  category      String
  amount        Float
  description   String?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([date])
}

model AdminLog {
  id            String   @id @default(cuid())
  action        String
  detail        String?
  ip            String?
  targetRestaurantId String?
  createdAt     DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([targetRestaurantId])
}
